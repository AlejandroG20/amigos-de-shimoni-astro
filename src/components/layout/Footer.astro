---
// Datos
import { site } from "@/data/site";
import { headerData } from "@/data/header";

// Astro
import { Image } from "astro:assets";

// Subcomponentes
import { Mail, Heart } from "lucide-astro";
import CtaButtonIcon from "@/components/ui/CtaButtonIcon.astro";
import SocialLinkCard from "@/components/ui/SocialLinkCard.astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-950 border-t border-secondary-800/20">
  <!-- Línea de acento -->
  <div
    class="h-0.5 bg-linear-to-r from-secondary-400 via-tertiary-400 to-primary-400"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 lg:py-20">
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-16"
    >
      <!-- Columna 1: Logo + descripción + redes -->
      <div class="flex flex-col gap-5">
        <a href="/" class="group flex items-center gap-3 w-fit">
          <div class="relative w-11 h-11">
            <div
              class="absolute inset-0 rounded-xl bg-linear-to-br from-secondary-400 to-tertiary-600 rotate-3 group-hover:rotate-6 transition-transform duration-300 opacity-80"
            >
            </div>
            <div
              class="relative w-full h-full rounded-xl overflow-hidden bg-primary-950 border border-secondary-700/40 flex items-center justify-center"
            >
              <Image
                src={headerData.logoImage ?? "/images/logo.webp"}
                alt={headerData.logoAlt ?? "Logo"}
                width={44}
                height={44}
                class="w-full h-full object-contain p-1"
              />
            </div>
          </div>
          <span
            class="font-heading font-bold italic text-lg bg-linear-to-r from-primary-200 via-white to-tertiary-300 bg-clip-text text-transparent whitespace-nowrap pr-1"
          >
            {site.name}
          </span>
        </a>

        <p class="font-body text-sm text-slate-400 leading-relaxed max-w-xs">
          {site.description}
        </p>

        <!-- Redes sociales -->
        <div class="flex items-center gap-3 mt-1">
          {headerData.socialLinks?.map((social) => <SocialLinkCard {...social} />)}
        </div>
      </div>

      <!-- Columna 2: Navegación + contacto info -->
      <div class="flex flex-col gap-5">
        <h3
          class="font-heading font-semibold text-sm uppercase tracking-widest text-secondary-400"
        >
          Navegación
        </h3>
        <ul class="flex flex-col gap-2">
          {
            headerData.navLinks?.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="font-body text-sm text-slate-400 hover:text-white transition-colors duration-200 flex items-center gap-2 group"
                >
                  <span class="w-3 h-px bg-secondary-700 group-hover:w-5 group-hover:bg-secondary-400 transition-all duration-200 rounded-full" />
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 3: Formulario de contacto -->
      <div class="flex flex-col gap-5" id="contact">
        <h3
          class="font-heading font-semibold text-sm uppercase tracking-widest text-secondary-400"
        >
          Contáctanos
        </h3>
        <p class="font-body text-sm text-slate-400">
          ¿Tienes alguna pregunta o quieres colaborar? Escríbenos.
        </p>

        <form id="contact-form" class="flex flex-col gap-3" novalidate>
          <div class="flex flex-col gap-1.5">
            <label
              for="footer-name"
              class="font-body text-xs font-medium text-slate-400"
            >
              Nombre
            </label>
            <input
              id="footer-name"
              type="text"
              name="name"
              placeholder="Tu nombre"
              autocomplete="name"
              class="w-full px-3 py-2 rounded-lg bg-primary-900/60 border border-secondary-800/30 text-sm text-white placeholder:text-slate-600 font-body focus:outline-none focus:border-secondary-600/60 focus:bg-primary-900/80 transition-all duration-200"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label
              for="footer-email"
              class="font-body text-xs font-medium text-slate-400"
            >
              Correo electrónico
            </label>
            <input
              id="footer-email"
              type="email"
              name="email"
              placeholder="tu@correo.com"
              autocomplete="email"
              class="w-full px-3 py-2 rounded-lg bg-primary-900/60 border border-secondary-800/30 text-sm text-white placeholder:text-slate-600 font-body focus:outline-none focus:border-secondary-600/60 focus:bg-primary-900/80 transition-all duration-200"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label
              for="footer-message"
              class="font-body text-xs font-medium text-slate-400"
            >
              Mensaje
            </label>
            <textarea
              id="footer-message"
              name="message"
              rows="3"
              placeholder="Escribe tu mensaje aquí..."
              class="w-full px-3 py-2 rounded-lg bg-primary-900/60 border border-secondary-800/30 text-sm text-white placeholder:text-slate-600 font-body focus:outline-none focus:border-secondary-600/60 focus:bg-primary-900/80 transition-all duration-200 resize-none"
            ></textarea>
          </div>

          <div id="contact-submit">
            <CtaButtonIcon type="submit" class="mt-1">
              <Mail slot="icon-start" size={14} />
              <span id="contact-submit-label">Enviar mensaje</span>
            </CtaButtonIcon>
          </div>

          <p id="contact-feedback" class="hidden font-body text-xs text-center rounded-lg px-3 py-2"></p>
        </form>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('contact-submit-label');
    const feedback = document.getElementById('contact-feedback');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || !submitLabel || !feedback) return;

      submitBtn.disabled = true;
      submitLabel.textContent = 'Enviando...';
      feedback.className = 'hidden font-body text-xs text-center rounded-lg px-3 py-2';

      const formData = new FormData(form);

      try {
        const res = await fetch('/api/contact', { method: 'POST', body: formData });
        const json = await res.json();

        if (res.ok) {
          feedback.textContent = '¡Mensaje enviado! Te responderemos pronto.';
          feedback.className = 'font-body text-xs text-center rounded-lg px-3 py-2 bg-green-900/40 text-green-300 border border-green-700/40';
          form.reset();
        } else {
          feedback.textContent = json.error ?? 'Error al enviar el mensaje.';
          feedback.className = 'font-body text-xs text-center rounded-lg px-3 py-2 bg-red-900/40 text-red-300 border border-red-700/40';
        }
      } catch {
        feedback.textContent = 'Error de conexión. Inténtalo de nuevo.';
        feedback.className = 'font-body text-xs text-center rounded-lg px-3 py-2 bg-red-900/40 text-red-300 border border-red-700/40';
      } finally {
        submitBtn.disabled = false;
        submitLabel.textContent = 'Enviar mensaje';
      }
    });
  </script>

  <!-- Barra legal inferior -->
  <div class="border-t border-secondary-800/20">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="font-body text-xs text-slate-500 text-center sm:text-left">
        © {currentYear}
        {site.legal.denominacion} · {site.legal.cif}
      </p>
      <p class="font-body text-xs text-slate-500 flex items-center gap-1.5">
        Hecho con <Heart
          size={11}
          class="text-secondary-500 fill-secondary-500"
        /> para Shimoni, Kenia
      </p>
    </div>
  </div>
</footer>
