---
// Datos
import { headerData } from "@/data/header";
import type { HeaderData } from "@/data/header";

// Subcomponentes
import HamburgerButton from "@/components/ui/HamburgerButton.astro";
import SocialLinkCard from "@/components/ui/SocialLinkCard.astro";
import CtaButton from "@/components/ui/CtaButton.astro";
import { ChevronRight } from "lucide-astro";

type Props = Partial<HeaderData>;

const props = Astro.props;

// Datos Default
const {
  name = headerData.name ?? "Tu Nombre",
  logoImage = headerData.logoImage ?? "/images/logo.png",
  logoAlt = headerData.logoAlt ?? "Logo",
  logoHref = headerData.logoHref ?? "/",
  ctaLabel = headerData.ctaLabel ?? "Contáctame",
  ctaHref = headerData.ctaHref ?? "#contact",
  navLinks = headerData.navLinks ?? [],
  socialLinks = headerData.socialLinks ?? [],
} = props;
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
>
  <!-- Fondo glassmorphism -->
  <div
    class="absolute inset-0 bg-primary-950/85 backdrop-blur-xl border-b border-secondary-800/20 transition-all duration-500"
    id="header-bg"
  >
  </div>

  <!-- Línea de acento animada -->
  <div
    class="absolute top-0 left-0 right-0 h-0.5 bg-linear-to-r from-secondary-400 via-tertiary-400 to-primary-400 animate-shimmer"
  >
  </div>

  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 lg:h-22">
      <!-- Logo -->
      <a
        href={logoHref}
        class="group flex items-center gap-4 shrink-0 cursor-pointer"
        aria-label={`Ir al inicio - ${name}`}
      >
        <div
          class="relative w-12 h-12 lg:w-14 lg:h-14 group-hover:scale-105 transition-transform duration-300"
        >
          <div
            class="absolute inset-0 rounded-xl bg-linear-to-br from-secondary-400 to-tertiary-600 rotate-3 group-hover:rotate-6 transition-transform duration-300 opacity-80 group-hover:opacity-100"
          >
          </div>
          <div
            class="relative w-full h-full rounded-xl overflow-hidden bg-primary-950 border border-secondary-700/40 flex items-center justify-center shadow-lg"
          >
            <img
              src={logoImage}
              alt={logoAlt}
              width="56"
              height="56"
              class="w-full h-full object-contain drop-shadow-md p-1"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>

        <!--  Nombre -->
        <span
          class="font-heading font-bold italic text-xl lg:text-2xl bg-linear-to-r from-secondary-200 via-white to-tertiary-300 bg-clip-text text-transparent group-hover:from-secondary-100 group-hover:via-white group-hover:to-tertiary-200 transition-all duration-300 tracking-tight pr-1"
        >
          {name}
        </span>
      </a>

      <!-- Navegación escritorio -->
      <div class="hidden md:flex items-center gap-1 lg:gap-2">
        {
          navLinks.map((item) => (
            <a
              href={item.href}
              class="nav-link relative px-3 lg:px-4 py-2 font-body text-sm font-medium text-slate-300 hover:text-white transition-colors duration-200 group cursor-pointer"
            >
              <span class="relative z-10">{item.label}</span>
              <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-linear-to-r from-primary-400 to-tertiary-400 group-hover:w-full transition-all duration-300 rounded-full" />
              <span class="absolute inset-0 rounded-lg bg-secondary-900/0 group-hover:bg-primary-900/25 transition-all duration-200" />
            </a>
          ))
        }
      </div>

      <!-- CTA + Sociales escritorio -->
      <div class="hidden md:flex items-center gap-3">
        <div class="flex items-center gap-2 mr-2">
          {socialLinks.map((social) => <SocialLinkCard {...social} />)}
        </div>
        <CtaButton href={ctaHref} label={ctaLabel} variant="solid" />
      </div>

      <!-- Botón hamburguesa móvil -->
      <HamburgerButton />
    </div>
  </nav>

  <!-- Menú móvil desplegable -->
  <div
    id="mobile-menu"
    class="md:hidden absolute top-full left-0 right-0 overflow-hidden transition-all duration-700 ease-in-out max-h-0"
    aria-hidden="true"
  >
    <div
      class="bg-primary-950/95 backdrop-blur-xl border-b border-secondary-800/20 px-4 pt-2 pb-6 space-y-1"
    >
      {
        navLinks.map((item, i) => (
          <a
            href={item.href}
            class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl font-body font-medium text-slate-300 hover:text-white hover:bg-primary-900/40 transition-all duration-200 group cursor-pointer mobile-menu-item"
            style={`--item-index: ${i}`}
          >
            {item.icon && <item.icon size={16} aria-hidden="true" />}
            <span>{item.label}</span>
            <ChevronRight
              size={16}
              class="ml-auto opacity-0 group-hover:opacity-100 text-secondary-400 transition-all duration-200 -translate-x-1 group-hover:translate-x-0"
            />
          </a>
        ))
      }

      <div
        class="my-3 h-px bg-linear-to-r from-transparent via-secondary-600 to-transparent"
      >
      </div>

      <div class="flex items-center justify-between px-2">
        <div class="flex items-center gap-3">
          {socialLinks.map((social) => <SocialLinkCard {...social} />)}
        </div>
        <CtaButton href={ctaHref} label={ctaLabel} />
      </div>
    </div>
  </div>
</header>

<!-- Espaciador para compensar el header fixed -->
<div class="h-18 lg:h-22"></div>

<style>
  #main-header.scrolled #header-bg {
    background: var(--color-primary-500);
    box-shadow: 0 1px 32px 0 rgba(232, 81, 101, 0.12);
  }

  #mobile-menu.open {
    max-height: 500px;
  }

  .mobile-menu-item {
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  #mobile-menu.open .mobile-menu-item {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(0.15s + var(--item-index) * 0.07s);
  }
  
  #main-header.menu-open #line1 {
    transform: rotate(45deg) translate(4px, 6px);
  }

  #main-header.menu-open #line2 {
    opacity: 0;
    transform: scaleX(0);
  }

  #main-header.menu-open #line3 {
    transform: rotate(-45deg) translate(4px, -6px);
  }
</style>

<script>
  const header = document.getElementById("main-header");
  const mobileMenuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  window.addEventListener(
    "scroll",
    () => {
      header?.classList.toggle("scrolled", window.scrollY > 20);
    },
    { passive: true },
  );

  mobileMenuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("open");
    mobileMenu?.classList.toggle("open");
    header?.classList.toggle("menu-open");
    mobileMenuBtn.setAttribute("aria-expanded", String(!isOpen));
    mobileMenu?.setAttribute("aria-hidden", String(isOpen));
  });

  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.remove("open");
      header?.classList.remove("menu-open");
      mobileMenuBtn?.setAttribute("aria-expanded", "false");
      mobileMenu?.setAttribute("aria-hidden", "true");
    });
  });

  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll(".nav-link");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const isActive =
              link.getAttribute("href") === `#${entry.target.id}`;
            link.classList.toggle("text-white", isActive);
            link.classList.toggle("text-slate-300", !isActive);
          });
        }
      });
    },
    { threshold: 0.5 },
  );

  sections.forEach((section) => observer.observe(section));
</script>
