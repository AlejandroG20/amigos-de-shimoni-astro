---
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "solid" | "outline";
  class?: string;
}

const { href, type = "button", variant = "solid", class: className = "" } = Astro.props;

const isSolid = variant === "solid";

const sharedClasses = [
  "inline-flex cursor-pointer items-center gap-2 rounded-xl px-6 py-3.5",
  "font-body text-sm font-bold transition-all duration-200",
  "hover:-translate-y-0.5",
  "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-600 focus-visible:ring-offset-2",
  isSolid && [
    "bg-primary-600 text-white shadow-sm shadow-primary-500/10",
    "hover:bg-primary-700 hover:shadow-md hover:shadow-primary-500/20",
  ],
  !isSolid && [
    "border-2 border-primary-200 text-primary-700",
    "hover:border-primary-500 hover:text-primary-600",
  ],
  className,
];
---

{
  href ? (
    <a href={href} class:list={sharedClasses}>
      <slot name="icon-start" />
      <slot />
      <slot name="icon-end" />
    </a>
  ) : (
    <button type={type} class:list={sharedClasses}>
      <slot name="icon-start" />
      <slot />
      <slot name="icon-end" />
    </button>
  )
}
