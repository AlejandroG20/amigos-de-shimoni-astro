---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { Heart, Users, Leaf, BookOpen } from "lucide-astro";
import { nosotrosData } from "@/data/nosotros";
import heroImg from "@/assets/images/hero.webp";

const { hero, historia, stats, valuesLabel, valuesTitle, values, teamLabel, teamTitle, teamDescription, team } = nosotrosData;

const iconMap = { Heart, Users, BookOpen, Leaf };

const colorMap = {
  primary:   { wrap: "bg-primary-100 text-primary-600" },
  secondary: { wrap: "bg-secondary-100 text-secondary-600" },
  tertiary:  { wrap: "bg-tertiary-100 text-tertiary-600" },
};

const statColors = [
  "bg-primary-50 text-primary-600",
  "bg-secondary-50 text-secondary-600",
  "bg-tertiary-50 text-tertiary-600",
  "bg-primary-50 text-primary-600",
];
---

<Layout title="Sobre Nosotros" description="Conoce a las personas detrás de Amigos de Shimoni y nuestra misión de apoyar a la comunidad de la costa de Kenia.">

  <section slot="main" class="relative overflow-hidden bg-white" aria-label="Sobre nosotros">

    <!-- ── Hero header ── -->
    <div class="relative overflow-hidden h-screen bg-primary-950 py-24 lg:py-32">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 opacity-20"
        style="background-image: radial-gradient(var(--color-primary-300) 1px, transparent 1px); background-size: 28px 28px;"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0
               bg-[radial-gradient(ellipse_70%_60%_at_50%_80%,color-mix(in_srgb,var(--color-primary-500)_20%,transparent),transparent)]"
      ></div>

      <div class="relative z-10 mx-auto max-w-4xl px-6 text-center lg:px-8">
        <span
          class="mb-5 inline-flex items-center gap-1.5 rounded-full
                 bg-primary-800/60 px-4 py-1.5
                 font-body text-xs font-semibold uppercase tracking-wider text-primary-200"
        >
          <Heart size={13} aria-hidden="true" />
          {hero.badge}
        </span>
        <h1
          class="mb-6 font-heading text-5xl font-extrabold leading-tight
                 tracking-tight text-white lg:text-6xl"
        >
          {hero.title}
          <span class="relative inline-block text-primary-300">
            {hero.titleHighlight}
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 h-1 w-full rounded-full
                     bg-linear-to-r from-primary-400 to-tertiary-400 animate-underline"
            ></span>
          </span>
        </h1>
        <p class="mx-auto max-w-2xl font-body text-lg leading-relaxed text-primary-200/80">
          {hero.description}
        </p>
      </div>
    </div>

    <!-- ── Nuestra historia ── -->
    <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">
        <div>
          <span class="mb-4 inline-block font-body text-sm font-semibold uppercase tracking-wider text-secondary-500">
            {historia.label}
          </span>
          <h2 class="mb-6 font-heading text-4xl font-extrabold leading-tight text-primary-950">
            {historia.title}
          </h2>
          <div class="space-y-4 font-body text-base leading-relaxed text-primary-800/70">
            {historia.paragraphs.map(p => <p>{p}</p>)}
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {stats.map((stat, i) => (
            <div class={`flex flex-col items-center justify-center rounded-2xl p-8 text-center ${statColors[i]}`}>
              <span class="font-heading text-4xl font-extrabold">{stat.value}</span>
              <span class="mt-1 font-body text-sm font-medium opacity-70">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ── Valores ── -->
    <div class="bg-primary-50/50 py-20 lg:py-28">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mb-14 text-center">
          <span class="mb-4 inline-block font-body text-sm font-semibold uppercase tracking-wider text-secondary-500">
            {valuesLabel}
          </span>
          <h2 class="font-heading text-4xl font-extrabold text-primary-950">
            {valuesTitle}
          </h2>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {values.map(({ icon, title, description, color }) => {
            const Icon = iconMap[icon];
            return (
              <div class="group rounded-2xl border border-primary-100 bg-white p-6 shadow-sm transition-shadow duration-300 hover:shadow-md">
                <div class={`mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl ${colorMap[color].wrap}`}>
                  <Icon size={22} aria-hidden="true" />
                </div>
                <h3 class="mb-2 font-heading text-lg font-bold text-primary-950">{title}</h3>
                <p class="font-body text-sm leading-relaxed text-primary-800/65">{description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- ── Equipo ── -->
    <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
      <div class="mb-14 text-center">
        <span class="mb-4 inline-block font-body text-sm font-semibold uppercase tracking-wider text-secondary-500">
          {teamLabel}
        </span>
        <h2 class="mb-4 font-heading text-4xl font-extrabold text-primary-950">
          {teamTitle}
        </h2>
        <p class="mx-auto max-w-xl font-body text-base leading-relaxed text-primary-800/65">
          {teamDescription}
        </p>
      </div>

      <div class="mx-auto grid max-w-3xl grid-cols-1 gap-8 sm:grid-cols-2">
        {team.map(member => (
          <article
            class="group flex flex-col overflow-hidden rounded-2xl border border-primary-100
                   bg-white shadow-sm transition-all duration-300
                   hover:-translate-y-1 hover:shadow-lg hover:shadow-primary-950/8"
          >
            <div class="relative overflow-hidden bg-primary-50">
              <div class="aspect-4/3 w-full">
                <img
                  src={member.image}
                  alt={`Foto de ${member.name}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div
                  class="absolute inset-0 hidden items-center justify-center
                         bg-linear-to-br from-primary-100 to-primary-200"
                  aria-hidden="true"
                >
                  <span class="font-heading text-4xl font-extrabold text-primary-500">
                    {member.initials}
                  </span>
                </div>
              </div>
              <span
                class="absolute bottom-3 left-3 rounded-full bg-white/90 px-3 py-1
                       font-body text-xs font-semibold text-primary-700 shadow-sm backdrop-blur-sm"
              >
                {member.role}
              </span>
            </div>

            <div class="flex flex-1 flex-col p-5">
              <h3 class="mb-1.5 font-heading text-lg font-bold text-primary-950">{member.name}</h3>
              <p class="font-body text-sm leading-relaxed text-primary-800/65">{member.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- ── Mapa de Shimoni ── -->
    <div class="bg-primary-950 py-20 lg:py-24">
      <div class="mx-auto max-w-5xl px-6 text-center lg:px-8">
        <span class="mb-4 inline-block font-body text-sm font-semibold uppercase tracking-wider text-primary-400">
          Dónde estamos
        </span>
        <h2 class="mb-4 font-heading text-4xl font-extrabold text-white">Shimoni, Kenia</h2>
        <p class="mb-10 font-body text-lg leading-relaxed text-primary-200/75">
          Un pequeño pueblo costero al sur de Kenia, junto al océano Índico, donde nació nuestra misión.
        </p>
        <div class="overflow-hidden rounded-2xl shadow-2xl shadow-black/40">
          <iframe
            title="Mapa de Shimoni, Kenia"
            src="https://www.openstreetmap.org/export/embed.html?bbox=39.3600%2C-4.6600%2C39.4000%2C-4.6200&layer=mapnik&marker=-4.6400%2C39.3800"
            width="100%"
            height="450"
            style="border: 0; display: block;"
            loading="lazy"
            allowfullscreen
          ></iframe>
        </div>
        <p class="mt-4 font-body text-sm text-primary-400/60">
          © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary-300">OpenStreetMap</a> contributors
        </p>
      </div>
    </div>

  </section>
</Layout>

<style>
  @keyframes underline-grow {
    from { transform: scaleX(0); transform-origin: left; }
    to   { transform: scaleX(1); transform-origin: left; }
  }
  .animate-underline {
    animation: underline-grow 0.8s 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-underline { animation: none; }
  }
</style>
